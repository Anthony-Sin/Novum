rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.userId == request.auth.uid 
          && data.email is string && data.email.size() <= 256
          && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
          && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 500))
          && data.createdAt is timestamp;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'email']);
    }

    // --- Threads ---
    match /threads/{threadId} {
      function isValidThread(data) {
        return isValidId(data.id) 
          && data.userId == request.auth.uid
          && data.title is string && data.title.size() <= 200
          && data.status in ['idle', 'hypothesizing', 'testing', 'completed']
          && data.prompt is string && data.prompt.size() <= 5000
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() 
        && isValidThread(incoming()) 
        && incoming().createdAt == request.time 
        && incoming().updatedAt == request.time;
      allow update: if isSignedIn() && existing().userId == request.auth.uid
        && isValidThread(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (
          // Action: Update status
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) ||
          // Action: Rename
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'updatedAt'])
        );
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;

      // --- Steps ---
      match /steps/{stepId} {
        function isValidStep(data) {
          return isValidId(data.id)
            && data.threadId == threadId
            && data.type in ['hypothesis', 'test', 'reflection', 'result']
            && data.agentName is string && data.agentName.size() <= 100
            && data.content is string && data.content.size() <= 10000
            && (data.findings == null || data.findings is list)
            && data.createdAt is timestamp;
        }

        allow list: if isSignedIn() && get(/databases/$(database)/documents/threads/$(threadId)).data.userId == request.auth.uid;
        allow get: if isSignedIn() && get(/databases/$(database)/documents/threads/$(threadId)).data.userId == request.auth.uid;
        allow create: if isSignedIn() 
          && get(/databases/$(database)/documents/threads/$(threadId)).data.userId == request.auth.uid
          && isValidStep(incoming())
          && incoming().createdAt == request.time;
      }
    }
  }
}
